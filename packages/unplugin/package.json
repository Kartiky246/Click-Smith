{
  "name": "@clicksmith/unplugin",
  "version": "0.1.0",
  "description": "Dev-only data-loc injection for ClickSmith across Vite/Rollup/Webpack/esbuild/Rspack. A hard no-op in production builds.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./vite": { "types": "./dist/vite.d.ts", "import": "./dist/vite.js" },
    "./rollup": { "types": "./dist/rollup.d.ts", "import": "./dist/rollup.js" },
    "./webpack": { "types": "./dist/webpack.d.ts", "import": "./dist/webpack.js" },
    "./rspack": { "types": "./dist/rspack.d.ts", "import": "./dist/rspack.js" },
    "./esbuild": { "types": "./dist/esbuild.d.ts", "import": "./dist/esbuild.js" }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@babel/parser": "^7.25.9",
    "@babel/traverse": "^7.25.9",
    "@babel/types": "^7.26.0",
    "magic-string": "^0.30.12",
    "unplugin": "^1.16.0"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.6"
  }
}
